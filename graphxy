<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>二元一次方程式圖形觀察</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800&family=ZCOOL+KuaiLe&display=swap" rel="stylesheet">
    <style>
        :root {
            --sky-blue: #87CEEB;
            --cloud-white: #F8FBF8;
            --grass-green: #7CB342;
            --dark-forest: #2E7D32;
            --wood-brown: #8D6E63;
            --text-dark: #3E2723;
        }

        body {
            font-family: 'Nunito', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #E8F5E9; 
            background-image: radial-gradient(#C8E6C9 1px, transparent 1px);
            background-size: 20px 20px;
            color: var(--text-dark);
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 0;
            padding: 20px;
        }

        h1 {
            font-family: 'ZCOOL KuaiLe', cursive; 
            color: var(--dark-forest);
            text-align: center;
            margin-bottom: 5px;
            font-size: 2.5rem;
            text-shadow: 2px 2px 0px rgba(255,255,255,0.8);
        }

        p.desc {
            color: #5D4037;
            margin-bottom: 20px;
            text-align: center;
            font-size: 1.1rem;
            font-weight: bold;
            background: rgba(255,255,255,0.6);
            padding: 5px 15px;
            border-radius: 20px;
        }

        .main-container {
            display: flex;
            flex-direction: column;
            width: 100%;
            max-width: 950px;
            gap: 20px;
        }

        .controls {
            background: #FFF9C4; 
            padding: 20px;
            border-radius: 20px;
            box-shadow: 0 8px 0 var(--wood-brown), 0 15px 20px rgba(0,0,0,0.1);
            border: 3px solid var(--wood-brown);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            position: relative;
        }

        .controls::before, .controls::after {
            content: '';
            position: absolute;
            top: -15px;
            width: 15px;
            height: 30px;
            background: var(--wood-brown);
            border-radius: 10px;
            box-shadow: inset -2px -2px rgba(0,0,0,0.2);
        }
        .controls::before { left: 20px; }
        .controls::after { right: 20px; }

        .input-group {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            justify-content: center;
            flex-wrap: wrap;
        }

        input[type="text"] {
            width: 250px;
            padding: 12px 15px;
            font-size: 1.3rem;
            font-family: 'Nunito', sans-serif;
            font-weight: bold;
            color: var(--dark-forest);
            border: 3px solid var(--grass-green);
            border-radius: 15px;
            text-align: center;
            background-color: var(--cloud-white);
            transition: all 0.3s;
        }
        input[type="text"]:focus {
            border-color: var(--dark-forest);
            outline: none;
            box-shadow: 0 0 10px rgba(124, 179, 66, 0.5);
        }
        input[type="text"]:disabled {
            background-color: #E0E0E0;
            border-color: #9E9E9E;
            color: #757575;
        }

        .btn-group {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
            justify-content: center;
        }

        button {
            font-family: 'Nunito', sans-serif;
            color: white;
            border: none;
            padding: 12px 24px;
            font-size: 1.1rem;
            font-weight: 800;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 5px 0 rgba(0,0,0,0.2);
            position: relative;
            top: 0;
        }
        button:hover {
            filter: brightness(1.1);
            transform: translateY(-2px);
            box-shadow: 0 7px 0 rgba(0,0,0,0.2);
        }
        button:active {
            transform: translateY(5px);
            box-shadow: 0 0 0 rgba(0,0,0,0.2);
        }
        button:disabled {
            background-color: #BDBDBD !important;
            box-shadow: 0 5px 0 #9E9E9E !important;
            cursor: not-allowed;
            transform: none !important;
            filter: none !important;
        }

        .btn-ready { background-color: var(--grass-green); box-shadow: 0 5px 0 var(--dark-forest); }
        .btn-clear { background-color: #FF7043; box-shadow: 0 5px 0 #D84315; }
        
        .step-panel {
            display: none;
            background-color: rgba(255,255,255,0.7);
            border: 2px dashed var(--wood-brown);
            padding: 15px;
            border-radius: 15px;
            width: 100%;
            box-sizing: border-box;
            text-align: center;
        }
        .step-panel.active {
            display: block;
            animation: floatUp 0.5s ease-out;
        }
        
        @keyframes floatUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .density-btns {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 10px;
            margin-bottom: 10px;
        }
        .btn-density { background-color: #5C6BC0; box-shadow: 0 5px 0 #3949AB; }

        .content-area {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
            align-items: flex-start;
        }

        .canvas-container {
            flex: 1.2;
            min-width: 350px;
            max-width: 500px;
            display: flex;
            flex-direction: column;
            align-items: center;
            background: var(--cloud-white);
            border-radius: 20px;
            padding: 10px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 4px solid var(--sky-blue);
        }
        canvas {
            background: transparent;
            width: 100%;
            height: auto;
            border-radius: 10px;
        }

        .info-panel {
            flex: 1;
            min-width: 300px;
            background: var(--cloud-white);
            border-radius: 20px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            max-height: 500px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 4px solid var(--wood-brown);
        }
        
        .status-box {
            padding: 12px 20px;
            border-radius: 20px;
            margin-bottom: 15px;
            font-weight: 800;
            text-align: center;
            background-color: white;
            color: var(--dark-forest);
            border: 2px solid var(--grass-green);
            position: relative;
            box-shadow: 2px 2px 0 rgba(0,0,0,0.1);
        }
        .status-box::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            margin-left: -10px;
            border-width: 10px 10px 0;
            border-style: solid;
            border-color: var(--grass-green) transparent transparent transparent;
            display: block;
            width: 0;
        }

        .table-container {
            overflow-y: auto;
            flex-grow: 1;
            border: 2px solid #E0E0E0;
            border-radius: 10px;
            background: white;
            scroll-behavior: smooth;
        }
        
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            text-align: center;
        }
        th {
            background-color: var(--sky-blue);
            color: white;
            padding: 12px 8px;
            font-weight: 800;
            font-size: 1.1rem;
            position: sticky;
            top: 0;
            z-index: 1;
            border-bottom: 3px solid #4FC3F7;
        }
        td {
            padding: 8px 6px;
            border-bottom: 1px dashed #E0E0E0;
            font-family: 'Nunito', Courier, monospace;
            font-weight: bold;
            font-size: 1.1rem;
        }
        tr.row-int td { color: #E65100; } 
        tr.row-dec td { color: #9C27B0; } 
        
        /* 剛加入表格時的淡入動畫 */
        .new-row { animation: highlight 1s ease-out; }
        @keyframes highlight {
            0% { background-color: #FFF9C4; }
            100% { background-color: transparent; }
        }

        .divider-row td {
            background-color: #F5F5F5;
            color: #757575;
            font-size: 0.95rem;
            padding: 10px;
            font-weight: bold;
        }

        .parsed-eq {
            font-size: 1rem;
            color: var(--wood-brown);
            text-align: center;
            font-weight: bold;
            margin-top: 5px;
            background: rgba(255,255,255,0.5);
            padding: 2px 10px;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <h1>二元一次方程式圖形觀察</h1>
    <p class="desc">自訂精度觀察解的座標：點越密集，圖形越接近一條直線</p>
    
    <div class="main-container">
        <!-- 控制區 -->
        <div class="controls">
            <div class="input-group">
                <label style="font-weight:900; font-size:1.2rem; color: var(--wood-brown);">方程式：</label>
                <input type="text" id="eqInput" value="2x + y = 4" placeholder="例如：x - y = 2">
            </div>
            <div class="parsed-eq" id="parsedResult">請輸入方程式後點擊「開始」</div>
            
            <div class="btn-group" id="mainBtnGroup">
                <button id="startBtn" class="btn-ready" onclick="startStage1()">▶ 第一階段：尋找整數解 (間距 1)</button>
                <button class="btn-clear" onclick="resetCanvas()">重新設定</button>
            </div>

            <!-- 精度選擇面板 -->
            <div class="step-panel" id="stepPanel">
                <div style="font-weight:800; color:var(--dark-forest); font-size:1.1rem;">第二階段：繼續尋找小數解</div>
                <div style="font-size:0.95rem; color:#5D4037; margin-bottom:8px; margin-top:5px;">請選擇 x 的間隔大小，可以重複點擊不同的精度：</div>
                <div class="density-btns">
                    <button class="btn-density" onclick="drawPointsWithStep(0.5, 4)">間隔 0.5 (點五)</button>
                    <button class="btn-density" onclick="drawPointsWithStep(0.1, 2)">間隔 0.1</button>
                    <button class="btn-density" onclick="drawPointsWithStep(0.02, 1)">間隔 0.02 (極密)</button>
                </div>
                <hr style="border: 0; border-top: 2px dashed #BCAAA4; margin: 15px 0;">
                <button id="finalBtn" class="btn-ready" onclick="startStage3()">▶ 第三階段：直接連成直線</button>
            </div>
        </div>

        <!-- 內容區 -->
        <div class="content-area">
            <div class="canvas-container">
                <canvas id="graphCanvas" width="500" height="500"></canvas>
            </div>
            
            <div class="info-panel">
                <div class="status-box" id="statusText">等待操作...</div>
                
                <div class="table-container" id="tableContainer">
                    <table id="solutionTable">
                        <thead>
                            <tr>
                                <th>x</th>
                                <th>y</th>
                                <th>數對 (x, y)</th>
                            </tr>
                        </thead>
                        <tbody id="solutionTbody">
                            <!-- 資料動態生成 -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('graphCanvas');
        const ctx = canvas.getContext('2d');
        const statusText = document.getElementById('statusText');
        const eqInput = document.getElementById('eqInput');
        const parsedResult = document.getElementById('parsedResult');
        const solutionTbody = document.getElementById('solutionTbody');
        const tableContainer = document.getElementById('tableContainer');
        const stepPanel = document.getElementById('stepPanel');
        const startBtn = document.getElementById('startBtn');
        
        const width = canvas.width;
        const height = canvas.height;
        const scale = 25; 
        const originX = width / 2;
        const originY = height / 2;
        
        let animationId;
        let currentEqData = null; 
        let drawnPointsCache = new Set(); 
        
        // 新增：統一管理表格資料的陣列
        let currentTableData = []; 
        let currentTableFooter = ""; // 表格底部的提示文字

        function formatNum(num) { return parseFloat(num.toFixed(4)); }
        function isInt(num) { return Math.abs(num - Math.round(num)) < 0.0001; }

        function initCanvas() {
            ctx.clearRect(0, 0, width, height);
            
            ctx.strokeStyle = 'rgba(135, 206, 235, 0.3)'; 
            ctx.lineWidth = 1;
            for (let i = 0; i <= width; i += scale) {
                ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, height); ctx.stroke();
            }
            for (let i = 0; i <= height; i += scale) {
                ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(width, i); ctx.stroke();
            }
            drawAxes();
        }

        function drawAxes() {
            ctx.strokeStyle = '#5D4037'; 
            ctx.lineWidth = 3;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            ctx.beginPath(); 
            ctx.moveTo(0, originY); 
            ctx.lineTo(width - 2, originY);
            ctx.stroke(); 
            
            ctx.beginPath(); 
            ctx.moveTo(originX, 2); 
            ctx.lineTo(originX, height); 
            ctx.stroke(); 

            // X 軸正向箭頭
            ctx.fillStyle = '#5D4037';
            ctx.beginPath();
            ctx.moveTo(width - 2, originY);
            ctx.lineTo(width - 14, originY - 6);
            ctx.lineTo(width - 14, originY + 6);
            ctx.fill();

            // Y 軸正向箭頭
            ctx.beginPath();
            ctx.moveTo(originX, 2);
            ctx.lineTo(originX - 6, 14);
            ctx.lineTo(originX + 6, 14);
            ctx.fill();
            
            ctx.fillStyle = '#5D4037';
            ctx.font = 'bold 12px Nunito';
            ctx.textAlign = 'center';
            for (let i = -10; i <= 10; i += 2) {
                if (i !== 0) {
                    ctx.fillText(i, originX + i * scale, originY + 18); 
                    ctx.fillText(-i, originX - 18, originY + i * scale + 5); 
                }
            }
            
            ctx.font = 'italic bold 18px Nunito';
            ctx.fillText('x', width - 20, originY - 15);
            ctx.fillText('y', originX + 22, 18);
        }

        function getCanvasX(x) { return originX + x * scale; }
        function getCanvasY(y) { return originY - y * scale; }

        function drawPoint(x, y, color, size, glowColor = null) {
            let cx = getCanvasX(x);
            let cy = getCanvasY(y);
            
            if (glowColor) {
                ctx.beginPath();
                ctx.arc(cx, cy, size * 2.5, 0, Math.PI * 2);
                ctx.fillStyle = glowColor;
                ctx.fill();
            }

            ctx.beginPath();
            ctx.arc(cx, cy, size, 0, Math.PI * 2);
            ctx.fillStyle = color;
            ctx.fill();
            
            if (size > 2) {
                ctx.strokeStyle = '#FFF9C4'; 
                ctx.lineWidth = 1.5;
                ctx.stroke();
            }
        }

        // 新增：統一渲染表格的函數（排序驅動）
        function renderTable(newPointKey = null) {
            solutionTbody.innerHTML = '';
            
            // 根據是否為垂直線決定排序基準 (一般依 x，垂直線依 y)
            const isVertical = currentEqData && currentEqData.b === 0;
            
            currentTableData.sort((p1, p2) => {
                if (isVertical) return p1.y - p2.y;
                return p1.x - p2.x;
            });

            currentTableData.forEach(pt => {
                let tr = document.createElement('tr');
                tr.className = pt.type === 'int' ? 'row-int' : 'row-dec';
                
                // 如果是最新加入的點，加上動畫效果
                let currentKey = `${pt.x},${pt.y}`;
                if (currentKey === newPointKey) {
                    tr.classList.add('new-row');
                }
                
                let tdX = document.createElement('td'); tdX.innerText = pt.x;
                let tdY = document.createElement('td'); tdY.innerText = pt.y;
                let tdPair = document.createElement('td'); tdPair.innerText = `(${pt.x}, ${pt.y})`;
                
                tr.appendChild(tdX); tr.appendChild(tdY); tr.appendChild(tdPair);
                solutionTbody.appendChild(tr);
            });

            // 如果有底部提示文字，加在最後面
            if (currentTableFooter) {
                let tr = document.createElement('tr');
                tr.className = 'divider-row';
                let td = document.createElement('td');
                td.colSpan = 3;
                td.innerText = currentTableFooter;
                tr.appendChild(td);
                solutionTbody.appendChild(tr);
            }
            
            // 讓表格自動滾動到最底部
            tableContainer.scrollTop = tableContainer.scrollHeight;
        }

        function parseEquation(eqStr) {
            eqStr = eqStr.replace(/\s+/g, '').toLowerCase();
            let parts = eqStr.split('=');
            if (parts.length !== 2) return null;

            function parseExpr(expr) {
                let a = 0, b = 0, c = 0;
                if (expr[0] !== '+' && expr[0] !== '-') expr = '+' + expr;
                expr = expr.replace(/-/g, '+-');
                let terms = expr.split('+');
                for (let term of terms) {
                    if (!term) continue;
                    let match = term.match(/^([+-]?\d*\.?\d*)([xy]?)$/);
                    if (match) {
                        let coeffStr = match[1];
                        let varName = match[2];
                        let coeff = 1;
                        if (coeffStr === '+' || coeffStr === '') coeff = 1;
                        else if (coeffStr === '-') coeff = -1;
                        else coeff = parseFloat(coeffStr);

                        if (varName === 'x') a += coeff;
                        else if (varName === 'y') b += coeff;
                        else c += coeff;
                    } else return null;
                }
                return {a, b, c};
            }

            let left = parseExpr(parts[0]);
            let right = parseExpr(parts[1]);
            if (!left || !right) return null;

            let a = left.a - right.a;
            let b = left.b - right.b;
            let c = -(left.c - right.c);

            return {a: formatNum(a), b: formatNum(b), c: formatNum(c)};
        }

        function setStatus(text, type = 'info') {
            statusText.innerText = text;
            if(type === 'error') {
                statusText.style.borderColor = '#E53935';
                statusText.style.color = '#E53935';
            } else if (type === 'success') {
                statusText.style.borderColor = '#43A047';
                statusText.style.color = '#2E7D32';
            } else {
                statusText.style.borderColor = '#7CB342';
                statusText.style.color = '#2E7D32';
            }
        }

        function resetCanvas() {
            if(animationId) clearTimeout(animationId);
            currentEqData = null;
            drawnPointsCache.clear();
            currentTableData = [];
            currentTableFooter = "";
            
            eqInput.disabled = false;
            startBtn.disabled = false;
            startBtn.style.display = "block";
            stepPanel.classList.remove('active');
            
            renderTable();
            parsedResult.innerText = "請輸入方程式後點擊「開始」";
            setStatus("等待操作...", "info");
            
            initCanvas();
        }

        function startStage1() {
            const eqStr = eqInput.value;
            const parsed = parseEquation(eqStr);

            if (!parsed) { setStatus("錯誤：方程式格式無法辨識。", "error"); return; }
            const {a, b, c} = parsed;
            if (a === 0 && b === 0) { setStatus("錯誤：x 和 y 的係數不能同時為 0！", "error"); return; }

            eqInput.disabled = true; 
            startBtn.disabled = true;

            let signB = b >= 0 ? '+' : '-';
            parsedResult.innerText = `標準化結果： ${a}x ${signB} ${Math.abs(b)}y = ${c}`;
            
            currentEqData = {a, b, c};
            drawnPointsCache.clear();
            currentTableData = [];
            currentTableFooter = "";
            
            setStatus("階段 1：尋找整數解中...", "info");

            let pointsToDraw = [];
            
            // 限定範圍，避免表格無限長 (擷取 -10 ~ 10 的範圍)
            if (Math.abs(b) > 0) {
                for (let x = -10; x <= 10; x++) {
                    let y = (c - a * x) / b;
                    if (isInt(y) && y >= -15 && y <= 15) {
                        pointsToDraw.push({x, y: Math.round(y)});
                    }
                }
                if(pointsToDraw.length === 0){
                    for (let x = -6; x <= 6; x += 3) {
                         pointsToDraw.push({x, y: formatNum((c - a * x) / b)});
                    }
                }
            } else {
                let fixedX = formatNum(c / a);
                for (let y = -10; y <= 10; y += 2) {
                    pointsToDraw.push({x: fixedX, y});
                }
            }

            let i = 0;
            function drawAnim() {
                if (i < pointsToDraw.length) {
                    let pt = pointsToDraw[i];
                    drawPoint(pt.x, pt.y, '#FF5722', 7, 'rgba(255, 193, 7, 0.4)');
                    
                    // 加入表格資料庫並重新渲染
                    currentTableData.push({x: pt.x, y: pt.y, type: 'int'});
                    renderTable(`${pt.x},${pt.y}`);
                    
                    drawnPointsCache.add(`${pt.x},${pt.y}`);
                    i++;
                    animationId = setTimeout(drawAnim, 400); 
                } else {
                    startBtn.style.display = "none";
                    stepPanel.classList.add('active');
                    setStatus("整數解尋找完畢！請在上方選擇更小的間隔繼續尋找小數解。", "success");
                }
            }
            drawAnim();
        }

        function drawPointsWithStep(step, dotSize) {
            if(animationId) clearTimeout(animationId);
            
            let btns = stepPanel.querySelectorAll('button');
            btns.forEach(btn => btn.disabled = true);
            
            setStatus(`正在尋找間距為 ${step} 的解...`, "info");

            const {a, b, c} = currentEqData;
            let pointsToDraw = [];
            
            // 取範圍內的所有點
            if (Math.abs(b) > 0) {
                let steps = Math.floor(12 / step); // 只取 -12 到 12 之間的點，以免算太多
                for (let i = -steps; i <= steps; i++) {
                    let x = formatNum(i * step);
                    let y = formatNum((c - a * x) / b);
                    let key = `${x},${y}`;
                    
                    if (!drawnPointsCache.has(key) && y >= -16 && y <= 16) {
                        pointsToDraw.push({x, y});
                        drawnPointsCache.add(key);
                    }
                }
            } else {
                let fixedX = formatNum(c / a);
                let steps = Math.floor(12 / step);
                for (let i = -steps; i <= steps; i++) {
                    let y = formatNum(i * step);
                    let key = `${fixedX},${y}`;
                    if (!drawnPointsCache.has(key)) {
                        pointsToDraw.push({x: fixedX, y});
                        drawnPointsCache.add(key);
                    }
                }
            }

            // 確保要畫的點本身是排序好的，這樣動畫看起來會順暢
            pointsToDraw.sort((p1, p2) => (b === 0) ? p1.y - p2.y : p1.x - p2.x);

            let i = 0;
            // 0.5 畫慢一點讓表格更新可見，更小的畫快一點
            let speed = step === 0.5 ? 200 : (step === 0.1 ? 10 : 1);
            let batchSize = step === 0.5 ? 1 : (step === 0.1 ? 5 : 20);

            function drawAnim() {
                if (i < pointsToDraw.length) {
                    let shouldRender = false;
                    let lastAddedKey = null;

                    for(let b_idx=0; b_idx<batchSize && i < pointsToDraw.length; b_idx++, i++){
                        let pt = pointsToDraw[i];
                        
                        if(step >= 0.1) {
                            drawPoint(pt.x, pt.y, '#9C27B0', dotSize, 'rgba(156, 39, 176, 0.2)'); 
                        } else {
                            drawPoint(pt.x, pt.y, '#7B1FA2', dotSize); 
                        }
                        
                        // 【關鍵修改】：只有在 step 為 0.5 時，才把點加入表格
                        // 且限制在 x -10 到 10 範圍內，確保表格不會無止盡變長
                        if (step === 0.5 && Math.abs(pt.x) <= 10 && Math.abs(pt.y) <= 15) {
                            currentTableData.push({x: pt.x, y: pt.y, type: 'dec'});
                            lastAddedKey = `${pt.x},${pt.y}`;
                            shouldRender = true;
                        }
                    }

                    // 如果有新點加入，重新排序並渲染表格
                    if (shouldRender) {
                        renderTable(lastAddedKey);
                    }
                    
                    animationId = setTimeout(drawAnim, speed);
                } else {
                    // 動畫結束後的處理
                    if (step < 0.5) {
                        // 針對 0.1 和 0.02，不加進表格，只在底部加提示
                        currentTableFooter = `(圖形上已額外畫出 ${pointsToDraw.length} 個密集的解)`;
                        renderTable();
                    }

                    btns.forEach(btn => btn.disabled = false);
                    setStatus(`已畫出間距 ${step} 的解。你可以選擇更小的間距，或直接連線。`, "success");
                }
            }
            drawAnim();
        }

        function startStage3() {
            if(animationId) clearTimeout(animationId);
            
            let btns = stepPanel.querySelectorAll('button');
            btns.forEach(btn => btn.disabled = true);
            
            setStatus("解有無限多個，當這些點無限密集時，就形成了一條實線。", "success");
            
            currentTableFooter = "===== 點緊密相連，形成直線 =====";
            renderTable();

            let {a, b, c} = currentEqData;
            ctx.beginPath();
            if (Math.abs(b) > 0) {
                let startX = -16;
                let startY = (c - a * startX) / b;
                let endX = 16;
                let endY = (c - a * endX) / b;
                ctx.moveTo(getCanvasX(startX), getCanvasY(startY));
                ctx.lineTo(getCanvasX(endX), getCanvasY(endY));
            } else {
                let startX = c / a;
                ctx.moveTo(getCanvasX(startX), getCanvasY(-16));
                ctx.lineTo(getCanvasX(startX), getCanvasY(16));
            }
            
            ctx.strokeStyle = '#43A047'; 
            ctx.lineWidth = 4;
            ctx.lineCap = 'round';
            ctx.shadowColor = 'rgba(67, 160, 71, 0.4)';
            ctx.shadowBlur = 8;
            ctx.stroke();
            ctx.shadowBlur = 0; 
        }

        initCanvas();
        
        eqInput.addEventListener("keypress", function(event) {
            if (event.key === "Enter" && !eqInput.disabled) {
                event.preventDefault();
                startStage1();
            }
        });
    </script>
</body>
